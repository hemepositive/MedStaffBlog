---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import StreamList from '../components/StreamList.astro';
import {
  getPostsNewestFirst,
  byCategory,
  isAttention,
  isPinned,
  postUrl,
  formatMonth,
} from '../lib/posts';

const posts = await getPostsNewestFirst();
const pinned = posts.filter((p) => isPinned(p));
// Newest 4 flagged posts get cards; older flagged posts keep their
// "Attention" chip in the streams below (flags never expire by date).
const attention = posts.filter((p) => isAttention(p)).slice(0, 4);
const announcements = byCategory(posts, 'announcements').slice(0, 3);
---

<Layout title="HH Medical Staff News">
  {pinned.map((post) => (
    <div class="pinned-notice">
      <div class="container">
        <span class="label">Notice</span>
        <a href={postUrl(post)}>{post.data.title} →</a>
      </div>
    </div>
  ))}

  <div class="container home">
    {attention.length > 0 && (
      <>
        <p class="zone-label">Needs your attention</p>
        <div class="attention">
          {attention.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </>
    )}

    <p class="zone-label">Latest by category</p>
    <div class="streams">
      <StreamList title="IT & EHR Updates" posts={byCategory(posts, 'it-ehr')} href="/it-updates" dot="var(--info)" />
      <StreamList title="Clinical Updates" posts={byCategory(posts, 'clinical')} href="/clinical" dot="var(--warning)" />
      <StreamList title="Education & CME" posts={byCategory(posts, 'education')} href="/education" dot="var(--edu)" />
    </div>

    {announcements.length > 0 && (
      <section class="announcements">
        <p class="zone-label">Announcements</p>
        <ul>
          {announcements.map((post) => (
            <li>
              <a href={postUrl(post)}>{post.data.title}</a>
              <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatMonth(post.data.date)}</time>
            </li>
          ))}
        </ul>
        <a class="view-all" href="/announcements">All announcements →</a>
      </section>
    )}
  </div>
</Layout>

<style>
  .pinned-notice {
    background: var(--critical-tint);
    border-bottom: 1px solid var(--line);
    font-size: 14.5px;
  }
  .pinned-notice .container {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding-top: 10px;
    padding-bottom: 10px;
  }
  .pinned-notice .label {
    color: var(--critical);
    font-weight: 700;
    letter-spacing: 0.05em;
    font-size: 12px;
    text-transform: uppercase;
  }
  .pinned-notice a {
    color: var(--ink);
    font-weight: 600;
  }

  .home {
    padding-top: 52px;
  }
  .attention {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
    gap: 24px;
    margin-bottom: 72px;
  }
  .streams {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 48px;
  }
  .announcements {
    margin-top: 72px;
  }
  .announcements ul {
    list-style: none;
  }
  .announcements li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    padding: 12px 2px;
    border-bottom: 1px solid var(--line);
  }
  .announcements li a {
    font-weight: 500;
    color: var(--ink);
    font-size: 15px;
  }
  .announcements li a:hover {
    color: var(--brand-ink);
  }
  .announcements time {
    font-size: 13px;
    color: var(--muted);
    flex: none;
  }
  .view-all {
    display: inline-block;
    margin-top: 14px;
    font-size: 14px;
    font-weight: 600;
  }
</style>
