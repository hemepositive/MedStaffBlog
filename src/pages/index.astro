---
import Layout from '../layouts/Layout.astro';
import Showcase from '../components/Showcase.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
posts.sort((a, b) => Date.parse(b.data.date) - Date.parse(a.data.date));

---

<Layout title="HH Medical Staff News">
  <Showcase heading="Medical Staff News" text="Periodic updates for our medical staff" />
  <section class="page-content">
    <div class="container">
      {posts.map(post => (
        <Card>
          <h3>{post.data.title}</h3>
          <div>
          Written by <strong>{post.data.author} </strong> on {new Date(post.data.date).toLocaleDateString()}
        </div>
          <p>{post.data.excerpt}</p>
          <a class="more-btn" href={`/${post.data.slug}`}>Read More</a>
        </Card>
      ))}
    </div>
  </section>
</Layout>


<style>
  
/* Prevent link color change when visited
a,
a:hover, 
a:active  
a:visited {
  color: inherit; 
  color: (var(--color-goldish));
}  */

.more-btn {
  display: inline-block;
  padding: 0.5rem 1rem;
  border-radius: 5px;
  background: var(--color-secondary);
  color: #fff;
  text-transform: uppercase;
  font-size: 0.8rem;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}
</style>