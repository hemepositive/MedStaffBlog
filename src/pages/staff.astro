---
import Layout from '../layouts/Layout.astro';

const staffData = [
  {
    name: 'Megan Leach',
    title: 'Director of Medical Staff Services',
    phone: '(256)265-2799',
  },
  {
    name: 'Elizabeth Haulenbeek',
    title: 'Credentialing Specialist - Physician Applicants',
    phone: '(256)265-6755',
  },
  {
    name: 'Nichelle Russell',
    title: 'Credentialing Specialist - Physician Reappointments',
    phone: '(256)265-8044',
  },
  {
    name: 'Mahalia Floyd',
    title: 'Credentialing Specialist - Allied Health Professional Applicants',
    phone: '(256)265-8856',
  },
  {
    name: 'Sierra Bonpua',
    title:
      'Credentialing Specialist - Allied Health Professional Reappointments',
    phone: '(256)265-8858',
  },
  {
    name: 'Brianna Ingram',
    title: 'Credentialing Specialist',
    phone: '(256)265-8920',
  },
];
---

<Layout title="The HH Medical Staff Office">
  <div class="container staff">
    <h1>The HH Medical Staff Office</h1>
    <div class="grid">
      {
        staffData.map((person) => (
          <div class="person">
            <h3>{person.name}</h3>
            <p class="role">{person.title}</p>
            <p class="phone num">{person.phone}</p>
          </div>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .staff {
    padding-top: 48px;
  }
  h1 {
    font-size: clamp(26px, 4vw, 34px);
    letter-spacing: -0.015em;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }
  .person {
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 22px 24px;
    box-shadow: var(--shadow);
  }
  .person h3 {
    font-size: 17px;
  }
  .role {
    font-size: 14px;
    color: var(--muted);
    margin: 4px 0 10px;
  }
  .phone {
    font-weight: 600;
    color: var(--brand-ink);
  }
</style>
