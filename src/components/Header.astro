---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/it-updates', label: 'IT & EHR' },
  { href: '/clinical', label: 'Clinical' },
  { href: '/education', label: 'Education' },
];
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const resourceLinks = [
  { href: '/leadership', label: 'Medical Staff Leadership' },
  { href: '/staff', label: 'Medical Staff Office' },
  { href: '/burnout', label: 'Burnout Help' },
  { href: '/NuDESC', label: 'NuDESC Tip Sheet' },
];
const resourcesActive = resourceLinks.some((l) => isActive(l.href));
---

<header class="site-header">
  <div class="inner">
    <a class="logo" href="/">
      <span class="logo-mark">H</span>
      <span class="logo-text">Med Staff News</span>
    </a>
    <nav class="pillars" aria-label="Sections">
      {links.map((l) => (
        <a href={l.href} class:list={[{ active: isActive(l.href) }]}>{l.label}</a>
      ))}
      <details class="resources-menu">
        <summary class:list={[{ active: resourcesActive }]}>
          Resources
          <span class="chevron" aria-hidden="true">⌄</span>
        </summary>
        <ul>
          {resourceLinks.map((l) => (
            <li><a href={l.href} class:list={[{ active: isActive(l.href) }]}>{l.label}</a></li>
          ))}
        </ul>
      </details>
    </nav>
    <button class="search-trigger" id="search-open" aria-label="Search the site">
      <span aria-hidden="true">⌕</span>
      <span class="search-hint">Search…</span>
      <kbd>⌘K</kbd>
    </button>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">◐</button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface-raised) 94%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 13px 28px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    color: var(--ink);
    font-size: 17px;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .logo:hover {
    text-decoration: none;
  }
  .logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--brand);
    color: #fff;
    display: grid;
    place-items: center;
    font-size: 16px;
    font-weight: 800;
    flex: none;
  }
  :global([data-theme='dark']) .logo-mark {
    color: #06211e;
  }
  .pillars {
    display: flex;
    gap: 4px;
    margin-left: 6px;
    overflow-x: auto;
  }
  .pillars a {
    font-size: 15px;
    font-weight: 500;
    padding: 7px 13px;
    border-radius: 8px;
    color: var(--body);
    white-space: nowrap;
  }
  .pillars a:hover {
    background: var(--surface-sunken);
    color: var(--ink);
    text-decoration: none;
  }
  .pillars a.active {
    color: var(--brand-ink);
    background: var(--brand-tint);
    font-weight: 600;
  }
  .resources-menu {
    position: relative;
  }
  .resources-menu summary {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 15px;
    font-weight: 500;
    padding: 7px 13px;
    border-radius: 8px;
    color: var(--body);
    white-space: nowrap;
    cursor: pointer;
    list-style: none;
  }
  .resources-menu summary::-webkit-details-marker {
    display: none;
  }
  .resources-menu summary:hover {
    background: var(--surface-sunken);
    color: var(--ink);
  }
  .resources-menu summary.active {
    color: var(--brand-ink);
    background: var(--brand-tint);
    font-weight: 600;
  }
  .resources-menu .chevron {
    font-size: 12px;
    transition: transform 0.15s ease;
  }
  .resources-menu[open] .chevron {
    transform: rotate(180deg);
  }
  .resources-menu ul {
    position: fixed;
    z-index: 60;
    list-style: none;
    min-width: 220px;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.14);
    padding: 6px;
  }
  .resources-menu li a {
    display: block;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 10px;
    border-radius: 7px;
    color: var(--body);
    white-space: nowrap;
  }
  .resources-menu li a:hover {
    background: var(--surface-sunken);
    color: var(--ink);
    text-decoration: none;
  }
  .resources-menu li a.active {
    color: var(--brand-ink);
    font-weight: 600;
  }
  .search-trigger {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--surface-sunken);
    padding: 8px 14px;
    min-width: 200px;
    color: var(--muted);
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
  }
  .search-trigger kbd {
    margin-left: auto;
    font-family: inherit;
    font-size: 11.5px;
    border: 1px solid var(--line);
    border-radius: 5px;
    background: var(--surface-raised);
    padding: 1px 6px;
  }
  .theme-toggle {
    flex: none;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: var(--surface-sunken);
    color: var(--body);
    font-size: 17px;
    cursor: pointer;
  }
  .theme-toggle:hover {
    color: var(--ink);
    border-color: var(--muted);
  }
  @media (max-width: 860px) {
    .inner {
      flex-wrap: wrap;
      row-gap: 8px;
    }
    .pillars {
      order: 3;
      width: 100%;
      margin-left: 0;
    }
    .search-trigger {
      min-width: 0;
    }
    .search-hint,
    .search-trigger kbd {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const current =
      root.dataset.theme ??
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = current === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });

  const resourcesMenu = document.querySelector<HTMLDetailsElement>('.resources-menu');
  const resourcesSummary = resourcesMenu?.querySelector('summary');
  const resourcesPanel = resourcesMenu?.querySelector<HTMLUListElement>('ul');

  function positionResourcesPanel() {
    if (!resourcesSummary || !resourcesPanel) return;
    const rect = resourcesSummary.getBoundingClientRect();
    const maxLeft = window.innerWidth - resourcesPanel.offsetWidth - 8;
    resourcesPanel.style.top = `${rect.bottom + 6}px`;
    resourcesPanel.style.left = `${Math.min(rect.left, Math.max(maxLeft, 8))}px`;
  }

  resourcesMenu?.addEventListener('toggle', () => {
    if (resourcesMenu.open) positionResourcesPanel();
  });
  window.addEventListener('resize', () => {
    if (resourcesMenu?.open) positionResourcesPanel();
  });

  document.addEventListener('click', (e) => {
    if (resourcesMenu?.open && !resourcesMenu.contains(e.target as Node)) {
      resourcesMenu.open = false;
    }
  });
  resourcesMenu?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') resourcesMenu.open = false;
  });
</script>
